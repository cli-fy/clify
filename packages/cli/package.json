{
  "name": "@clify/cli",
  "version": "0.1.0",
  "description": "Turn GitHub-hosted website API plugins into CLIs on demand.",
  "type": "module",
  "bin": {
    "clify": "./dist/bin.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.mjs --config-loader native",
    "coverage": "vitest run --config vitest.config.ts --coverage",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "bun run build && rm -rf template && cp -R ../template template"
  },
  "dependencies": {
    "incur": "^0.4.5",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {}
}
