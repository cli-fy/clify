{
  "name": "clify",
  "private": true,
  "packageManager": "bun@1.3.13",
  "type": "module",
  "workspaces": [
    "packages/cli"
  ],
  "scripts": {
    "build": "bun run --filter @clify/cli build",
    "changeset": "changeset",
    "coverage": "bun run --filter @clify/cli coverage",
    "release": "bun run build && bun publish --cwd packages/cli --access public",
    "test": "bun run --filter @clify/cli test",
    "typecheck": "bun run --filter @clify/cli typecheck",
    "version-packages": "changeset version",
    "lint": "biome check .",
    "format": "biome format --write .",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260510.1",
    "@vitest/coverage-v8": "3.2.4",
    "knip": "^5.50.0",
    "tsdown": "^0.16.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
